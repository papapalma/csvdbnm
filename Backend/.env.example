# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development

# Database (if using direct connection)
DATABASE_URL=your_database_connection_string

# API Configuration
API_PORT=3001
BACKEND_URL=http://localhost:3001

# Auth Migration Feature Flags
# Enable Supabase Auth integration (Phase 1-3)
FEATURE_SUPABASE_AUTH_ENABLED=false
# Use Supabase JWT verification instead of custom JWT
FEATURE_SUPABASE_JWT_VERIFICATION=false
# Enable optional app JWT exchange endpoint
FEATURE_APP_JWT_EXCHANGE=false

# Platform-level Email Configuration (fallback when tenant has no SMTP config)
# Used by emailService.ts when a tenant's notification.email config is absent
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_SENDER_NAME=Training Management System
SMTP_SENDER_EMAIL=noreply@example.com

# File Encryption (Req 21.4, 21.5)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotate every 90 days. Keep the old key in FILE_ENCRYPTION_KEY_PREV during transition.
FILE_ENCRYPTION_ENABLED=false
FILE_ENCRYPTION_KEY=your_64_char_hex_key_here
FILE_ENCRYPTION_KEY_PREV=

# Data Privacy (RA 10173, Req 22.6)
# Data Protection Officer email — used for breach notifications
DPO_EMAIL=dpo@your-lgu.gov.ph

# Backup Configuration (Req 20.5)
# Secret key for authenticating automated backup trigger requests (cron jobs)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_SECRET_KEY=your_backup_secret_key_here
# Number of days to retain backup files (default: 30)
BACKUP_RETENTION_DAYS=30
