# Environment Variables for BMDC Frontend

# ===================================
# API Configuration
# ===================================

# Backend API Base URL
# Development: http://localhost:3000/api
# Production: https://api.bmdc.com/api
VITE_API_BASE_URL=http://localhost:3000/api

# API Timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# ===================================
# Application Configuration
# ===================================

# Application Environment
VITE_APP_ENV=development

# Application Name
VITE_APP_NAME=BMDC Management System

# Application Version
VITE_APP_VERSION=1.0.0

# ===================================
# Authentication Configuration
# ===================================

# Token Storage Key
VITE_AUTH_TOKEN_KEY=auth_token

# Refresh Token Storage Key
VITE_REFRESH_TOKEN_KEY=refresh_token

# Session Timeout (in minutes)
VITE_SESSION_TIMEOUT=60

# ===================================
# Feature Flags
# ===================================

# Enable/Disable Features
VITE_ENABLE_PWA=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANOMALY_DETECTION=true
VITE_ENABLE_ACTIVITY_LOGGING=true

# ===================================
# Upload Configuration
# ===================================

# Max file upload size (in MB)
VITE_MAX_FILE_SIZE=10

# Allowed file types
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# ===================================
# Pagination Configuration
# ===================================

# Default items per page
VITE_DEFAULT_PAGE_SIZE=10

# Max items per page
VITE_MAX_PAGE_SIZE=100

# ===================================
# Cache Configuration
# ===================================

# Cache duration (in milliseconds)
VITE_CACHE_DURATION=300000

# Enable API response caching
VITE_ENABLE_CACHE=false

# ===================================
# Logging Configuration
# ===================================

# Enable console logging
VITE_ENABLE_LOGGING=true

# Log level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# ===================================
# Analytics Configuration
# ===================================

# Google Analytics ID (optional)
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# ===================================
# PWA Configuration
# ===================================

# Service Worker cache name
VITE_SW_CACHE_NAME=bmdc-cache-v1

# Offline mode enabled
VITE_ENABLE_OFFLINE=true

# ===================================
# Security Configuration
# ===================================

# Enable CORS
VITE_ENABLE_CORS=true

# CORS Allowed Origins
VITE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===================================
# Development Tools
# ===================================

# Enable React DevTools
VITE_ENABLE_DEVTOOLS=true

# Enable Redux DevTools
VITE_ENABLE_REDUX_DEVTOOLS=true

# Mock API Responses (for development)
VITE_USE_MOCK_API=false

# ===================================
# Notes:
# ===================================
# 1. Copy this file to .env.local for local development
# 2. Never commit .env.local to version control
# 3. All VITE_ prefixed variables are exposed to the client
# 4. Restart dev server after changing environment variables
# 5. Use import.meta.env.VITE_* to access these variables
