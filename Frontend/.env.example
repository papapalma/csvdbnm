# API Configuration
# Base URL for Backend API endpoints (includes /api suffix)
VITE_API_BASE_URL=http://localhost:3001/api

# Backend Base URL (for static file serving like images)
# This URL is used to construct full URLs for uploaded images and static files
# Development: Use localhost Backend server
VITE_BACKEND_URL=http://localhost:3001
# Production: Update to production Backend URL
# VITE_BACKEND_URL=https://bmdc.site/api
